    "system_summary.md - 系统总结"
  ],
  "system_requirements": {
    "python": ">=3.8",
    "browser": "Chrome 90+, Firefox 88+, Edge 90+",
    "os": "Windows 10+, macOS 10.15+, Linux",
    "memory": "4GB+",
    "storage": "200MB+"
  },
  "demo_data": {
